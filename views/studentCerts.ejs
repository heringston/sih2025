<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        table{
            border: 1px solid black;
        }
        td{
            border: 1px solid black;
        }
    </style>
</head>
<body>
    <% if(locals) { %>
        <table>
            <tr>
                <th>Name</th>
                <th>Reg No</th>
                <th>Course</th>
                <th>Validation</th>
            </tr>
        
        <% for(let i=0;i<certs.length;i++) {  %>
            <tr>
                <td><%= certs[i].sname %></td>
                <td><%= certs[i].reg %></td>
                <td><%= certs[i].course %></td>    
                <td><img width="70px" height="70px" src="<%= certs[i].qr %>" alt="error loading"></td>
            </tr>
        <% }%>
        </table>
    <% } %>
</body>
</html>